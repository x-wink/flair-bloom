{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlairBloom",
  "version": "0.2.1",
  "identifier": "fun.xwink.flairbloom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "tsc && pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "FlairBloom",
        "url": "/panel.html",
        "width": 405,
        "height": 720,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/x-wink/flair-bloom/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1NzQyOEYwNjJCRUQ4OUEKUldTYTJMNWk4Q2gwRmNZc2srbnMvYzJnTERlYkZnOXEzVnVPbFJ0RW91MUlMNXZlY05OVmdQQlQK"
    }
  }
}
