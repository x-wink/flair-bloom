{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlairBloom",
  "version": "0.1.0",
  "identifier": "com.flairbloom.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "tsc && pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "FlairBloom",
        "url": "/panel.html",
        "width": 900,
        "height": 600,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/x-wink/flair-bloom/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
