# GitHub Actions Secrets — 在仓库 Settings → Secrets → Actions 中配置以下变量
#
# 生成签名密钥：
#   cargo tauri signer generate -w ~/.tauri/flair-bloom.key
# 命令输出：
#   - 私钥（填入 TAURI_SIGNING_PRIVATE_KEY）
#   - 公钥（填入 tauri.conf.json → plugins.updater.pubkey）

TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
